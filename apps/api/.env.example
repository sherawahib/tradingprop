# PropPrime API — environment variables
#
# Copy to `apps/api/.env` for local development.

JWT_SECRET=change-me-in-production-32+chars

# ============================================================================
# Live market data — MT5 bridge
# ============================================================================
# The API spawns a local Python WebSocket bridge (api_bridge.py) that attaches
# to the broker's MetaTrader 5 terminal and streams real bid/ask ticks. Defaults
# below assume the Exness MT5 install lives at F:\algocheck.

# Set to "false" to disable auto-spawn (e.g. when you run the bridge yourself).
# MT5_BRIDGE_AUTOSTART=true

# Directory containing api_bridge.py and terminal64.exe.
# MT5_BRIDGE_DIR=F:\algocheck

# Path to the MT5 terminal executable. Defaults to <MT5_BRIDGE_DIR>\terminal64.exe
# MT5_TERMINAL_PATH=F:\algocheck\terminal64.exe

# Python interpreter to use when spawning the bridge.
# MT5_BRIDGE_PYTHON=python

# Local port for the bridge HTTP / WebSocket listener.
# MT5_BRIDGE_PORT=8000

# Override the WS URL if running the bridge remotely (skips auto-spawn checks).
# MT5_BRIDGE_WS_URL=ws://127.0.0.1:8000/ws/prices

# Optional comma-separated list of symbols to stream
# (default: full PropPrime tradeable list).
# MT5_SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD,XAGUSD,USOIL,BTCUSD,ETHUSD

# Optional account credentials if the terminal is not already logged in.
# MT5_LOGIN=
# MT5_PASSWORD=
# MT5_SERVER=

# Admin / partner bootstrap (optional)
# ADMIN_BOOTSTRAP_USERNAME=
# ADMIN_BOOTSTRAP_PASSWORD=

# Bank transfer checkout placeholders (optional)
# BANK_TRANSFER_BENEFICIARY=
# BANK_TRANSFER_BANK_NAME=
# BANK_TRANSFER_IBAN=
# BANK_TRANSFER_SWIFT=
# BANK_TRANSFER_CURRENCY=USD
# BANK_TRANSFER_REFERENCE_HINT=
