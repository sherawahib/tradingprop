{
  "name": "@paper-trader/desktop",
  "productName": "PropPrime Terminal",
  "version": "1.0.1",
  "private": true,
  "author": "PropPrime",
  "description": "PropPrime desktop trading terminal (Windows / Electron). Connects to the @paper-trader/api backend over HTTP + WebSocket. Independent from the web app.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5180 && tsc -p tsconfig.electron.json && cross-env ELECTRON_DEV=1 VITE_DEV_SERVER_URL=http://localhost:5180 electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "package": "npm run build && electron-builder --win nsis --x64",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "@paper-trader/shared": "*",
    "lightweight-charts": "^5.0.9",
    "lucide-react": "^0.479.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.11",
    "wait-on": "^9.0.5"
  }
}
